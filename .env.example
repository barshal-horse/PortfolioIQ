# PortfolioIQ Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://portfolioiq:portfolioiq_pass@localhost:5432/portfolioiq

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEFAULT_CURRENCY=USD
RISK_FREE_RATE=0.05

# Market Data (Phase 3+)
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=

# AI (Phase 10+)
# GEMINI_API_KEY=

# News (Phase 11+)
# FINNHUB_API_KEY=
# NEWSAPI_API_KEY=
